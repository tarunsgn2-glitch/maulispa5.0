{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/therapies",  "dest": "/therapies.html" },
    { "src": "/gallery",    "dest": "/gallery.html" },
    { "src": "/membership", "dest": "/membership.html" },
    { "src": "/about",      "dest": "/about.html" },
    { "src": "/contact",    "dest": "/contact.html" },
    { "src": "/more",       "dest": "/more.html" },
    { "src": "/blog",       "dest": "/blog.html" },
    { "src": "/(.*)",       "dest": "/$1" }
  ]
}
